staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$staged_files" ]; then
  exit 0
fi

if printf '%s\n' "$staged_files" | node scripts/docs-only.mjs; then
  echo "Documentation-only commit: running doc link checks."
  npm run check:docs
  exit 0
fi

echo "Running pre-commit checks: build client, lint, docs, boundaries, typecheck."
npm run verify:quick
