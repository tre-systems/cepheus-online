{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node10",
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "noEmit": false,
    "outDir": "build/test",
