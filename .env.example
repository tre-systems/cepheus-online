# Cepheus Online local environment template.
# Copy this file to .env and fill only the values you need.
# .env is ignored by git. Never commit real secrets or session cookies.

# Deployed smoke target. The smoke script also accepts a positional URL.
CEPHEUS_SMOKE_URL=https://cepheus.tre.systems
CEPHEUS_SMOKE_REQUIRE_AUTH=1

# Authenticated deployed smoke cookies.
# Use the full cookie pair, e.g. cepheus_session=..., or just the cookie value.
# The owner/referee cookie is enough for protected room creation and command
# flow. Use distinct signed-in Discord users for automated cross-role checks.
CEPHEUS_SMOKE_SESSION_COOKIE=
CEPHEUS_SMOKE_PLAYER_SESSION_COOKIE=
CEPHEUS_SMOKE_SPECTATOR_SESSION_COOKIE=

# Optional per-request timeout for smoke checks.
CEPHEUS_SMOKE_TIMEOUT_MS=15000

# Production Worker/OAuth configuration reference.
# In production, set SESSION_SECRET and DISCORD_CLIENT_SECRET with Wrangler or
# GitHub Actions secrets. APP_BASE_URL and DISCORD_CLIENT_ID are deployed as
# Worker vars by the GitHub Actions Deploy workflow.
APP_BASE_URL=https://cepheus.tre.systems
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
SESSION_SECRET=

# Cloudflare deployment credentials for local CLI use if needed.
# Prefer GitHub repository secrets for normal production deploys.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
