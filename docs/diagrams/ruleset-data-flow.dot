digraph RulesetDataFlow {
  graph [rankdir=TB, bgcolor="#ffffff", pad="0.55", nodesep="0.50", ranksep="0.78", splines=polyline, outputorder=edgesfirst, compound=true, newrank=true, forcelabels=true, fontname="Avenir", label=<
    <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD><FONT POINT-SIZE="34"><B>Ruleset Data Flow</B></FONT></TD></TR></TABLE>
  >, labelloc=t, labeljust=c];
  node [shape=box, style="rounded,filled", margin="0.21,0.13", width=2.70, height=0.72, fixedsize=false, fontname="Avenir", fontsize=18, penwidth=2.4, fontcolor="#14213d", color="#2264c7", fillcolor="#eaf3ff:#ffffff", gradientangle=270];
  edge [color="#263a59", fontname="Avenir", fontsize=13, fontcolor="#3d4a5c", penwidth=2.2, arrowsize=0.78];

  R1 [label=<<B>Bundled SRD JSON</B><BR/><FONT POINT-SIZE="15">data/rulesets</FONT>>];
  R2 [label=<<B>Future custom JSON</B><BR/><FONT POINT-SIZE="15">uploaded or imported ruleset data</FONT>>, fillcolor="#fff4d1:#fffaf0", color="#d39a00"];
  R3 [label=<<B>Ruleset provider</B><BR/><FONT POINT-SIZE="15">source boundary</FONT>>, fillcolor="#eaf8ef:#ffffff", color="#22865a"];
  R4 [label=<<B>Decode and validate</B><BR/><FONT POINT-SIZE="15">fail closed on malformed data</FONT>>];
  R5 [label=<<B>Resolved ruleset</B><BR/><FONT POINT-SIZE="15">id, version, contentHash, source, data</FONT>>, fillcolor="#d8f5de:#effcf2", color="#15803d", penwidth=3.0];
  R6 [label=<<B>Room ruleset reference</B><BR/><FONT POINT-SIZE="15">CreateGame, GameCreated, GameState</FONT>>];

  subgraph cluster_consumers {
    graph [label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="17" COLOR="#1f5fbf"><B>CONSUMERS</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#496f9f">Every rules decision uses decoded room-selected data.</FONT></TD></TR></TABLE>
    >, labelloc=t, labeljust=l, color="#b9d8ff", fillcolor="#f5faff", style="rounded,filled", penwidth=1.8, margin=20];
    C1 [label=<<B>Command publication</B><BR/><FONT POINT-SIZE="15">derive legal events</FONT>>];
    C2 [label=<<B>Projectors</B><BR/><FONT POINT-SIZE="15">event facts to state</FONT>>];
    C3 [label=<<B>Viewer projection</B><BR/><FONT POINT-SIZE="15">redact pending facts</FONT>>];
    C4 [label=<<B>Client creation views</B><BR/><FONT POINT-SIZE="15">legal actions and labels</FONT>>];
  }

  R1 -> R3;
  R2 -> R3 [style=dashed, color="#6b7280"];
  R3 -> R4 -> R5 -> R6;
  R5 -> C1 [lhead=cluster_consumers];
  R5 -> C2 [lhead=cluster_consumers];
  R5 -> C3 [lhead=cluster_consumers];
  R5 -> C4 [lhead=cluster_consumers];
}
