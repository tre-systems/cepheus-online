digraph CommandPublicationFlow {
  graph [rankdir=TB, bgcolor="#ffffff", pad="0.55", nodesep="0.50", ranksep="0.78", splines=polyline, outputorder=edgesfirst, compound=true, newrank=true, forcelabels=true, fontname="Avenir", label=<
    <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD><FONT POINT-SIZE="34"><B>Command Publication Flow</B></FONT></TD></TR></TABLE>
  >, labelloc=t, labeljust=c];
  node [shape=box, style="rounded,filled", margin="0.21,0.13", width=2.70, height=0.72, fixedsize=false, fontname="Avenir", fontsize=18, penwidth=2.4, fontcolor="#14213d", color="#2264c7", fillcolor="#eaf3ff:#ffffff", gradientangle=270];
  edge [color="#263a59", fontname="Avenir", fontsize=13, fontcolor="#3d4a5c", penwidth=2.2, arrowsize=0.78];

  A1 [label=<<B>Client command</B><BR/><FONT POINT-SIZE="15">requestId, actor, expectedSeq</FONT>>];
  A2 [label=<<B>Room command service</B><BR/><FONT POINT-SIZE="15">session and rate-limit gate</FONT>>, fillcolor="#eaf8ef:#ffffff", color="#22865a"];

  subgraph cluster_publication {
    graph [label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="17" COLOR="#1f5fbf"><B>PUBLICATION CORE</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#496f9f">Single mutation path for accepted room commands.</FONT></TD></TR></TABLE>
    >, labelloc=t, labeljust=l, color="#b9d8ff", fillcolor="#f5faff", style="rounded,filled", penwidth=1.8, margin=20];
    P1 [label=<<B>Load current state</B><BR/><FONT POINT-SIZE="15">checkpoint plus event tail</FONT>>];
    P2 [label=<<B>Command metadata</B><BR/><FONT POINT-SIZE="15">domain, seeded dice, stale policy</FONT>>];
    P3 [label=<<B>Resolve ruleset</B><BR/><FONT POINT-SIZE="15">decoded JSON data</FONT>>];
    P4 [label=<<B>Derive events</B><BR/><FONT POINT-SIZE="15">intent to facts</FONT>>];
    P5 [label=<<B>Append envelopes</B><BR/><FONT POINT-SIZE="15">version, seq, actor, time</FONT>>, fillcolor="#d8f5de:#effcf2", color="#15803d", penwidth=3.0];
    P6 [label=<<B>Project next state</B><BR/><FONT POINT-SIZE="15">authoritative read model</FONT>>];
    P7 [label=<<B>Checkpoint decision</B><BR/><FONT POINT-SIZE="15">natural boundary or cadence</FONT>>];
    P8 [label=<<B>Projection parity</B><BR/><FONT POINT-SIZE="15">stored projection matches live projection</FONT>>];
    P1 -> P2 -> P3 -> P4 -> P5 -> P6 -> P7 -> P8;
  }

  B1 [label=<<B>Viewer projection</B><BR/><FONT POINT-SIZE="15">role-safe state and activity</FONT>>, fillcolor="#fff4d1:#fffaf0", color="#d39a00"];
  B2 [label=<<B>Broadcast / response</B><BR/><FONT POINT-SIZE="15">accepted or roomState</FONT>>];

  A1 -> A2 -> P1 [lhead=cluster_publication];
  P8 -> B1 [ltail=cluster_publication];
  B1 -> B2;
}
