digraph ClientRuntimeBoundaries {
  graph [rankdir=TB, bgcolor="#ffffff", pad="0.55", nodesep="0.50", ranksep="0.78", splines=polyline, outputorder=edgesfirst, compound=true, newrank=true, forcelabels=true, fontname="Avenir", label=<
    <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD><FONT POINT-SIZE="34"><B>Client Runtime Boundaries</B></FONT></TD></TR></TABLE>
  >, labelloc=t, labeljust=c];
  node [shape=box, style="rounded,filled", margin="0.21,0.13", width=2.70, height=0.72, fixedsize=false, fontname="Avenir", fontsize=18, penwidth=2.4, fontcolor="#14213d", color="#2264c7", fillcolor="#eaf3ff:#ffffff", gradientangle=270];
  edge [color="#263a59", fontname="Avenir", fontsize=13, fontcolor="#3d4a5c", penwidth=2.2, arrowsize=0.78];

  E1 [label=<<B>app.ts</B><BR/><FONT POINT-SIZE="15">DOM entrypoint only</FONT>>, fillcolor="#d8f5de:#effcf2", color="#15803d", penwidth=3.0];
  E2 [label=<<B>createAppClient</B><BR/><FONT POINT-SIZE="15">runtime lifecycle API</FONT>>, fillcolor="#eaf8ef:#ffffff", color="#22865a"];

  subgraph cluster_runtime {
    graph [label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="17" COLOR="#1f5fbf"><B>APP RUNTIME</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#496f9f">Owns identity, authoritative state, transport, and render coordination.</FONT></TD></TR></TABLE>
    >, labelloc=t, labeljust=l, color="#b9d8ff", fillcolor="#f5faff", style="rounded,filled", penwidth=1.8, margin=20];
    R1 [label=<<B>Room transport</B><BR/><FONT POINT-SIZE="15">fetch and WebSocket connection</FONT>>];
    R2 [label=<<B>Command router</B><BR/><FONT POINT-SIZE="15">metadata, expectedSeq, request ids</FONT>>];
    R3 [label=<<B>Dice reveal coordinator</B><BR/><FONT POINT-SIZE="15">pending animation and refresh</FONT>>];
    R4 [label=<<B>Render coordinator</B><BR/><FONT POINT-SIZE="15">board, rail, sheet, creation</FONT>>];
  }

  subgraph cluster_features {
    graph [label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="17" COLOR="#8a5f00"><B>FEATURE BOUNDARIES</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#836b27">Feature modules receive commands and state through runtime callbacks.</FONT></TD></TR></TABLE>
    >, labelloc=t, labeljust=l, color="#f2cf78", fillcolor="#fffaf0", style="rounded,filled", penwidth=1.8, margin=20];
    F1 [label=<<B>Board</B>>, fillcolor="#fff4d1:#fffaf0", color="#d39a00"];
    F2 [label=<<B>Character rail</B>>, fillcolor="#fff4d1:#fffaf0", color="#d39a00"];
    F3 [label=<<B>Character sheet</B>>, fillcolor="#fff4d1:#fffaf0", color="#d39a00"];
    F4 [label=<<B>Character creation</B>>, fillcolor="#fff4d1:#fffaf0", color="#d39a00"];
  }

  E1 -> E2;
  E2 -> R1 [lhead=cluster_runtime];
  R1 -> R2;
  R2 -> R3;
  R3 -> R4;
  R4 -> F1 [ltail=cluster_runtime, lhead=cluster_features];
  R4 -> F4 [ltail=cluster_runtime, lhead=cluster_features];
}
