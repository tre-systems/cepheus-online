digraph RuntimeArchitecture {
  graph [
    rankdir=TB,
    bgcolor="#ffffff",
    pad="0.55",
    nodesep="0.50",
    ranksep="0.78",
    splines=polyline,
    outputorder=edgesfirst,
    compound=true,
    newrank=true,
    forcelabels=true,
    fontname="Avenir",
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0">
        <TR><TD><FONT POINT-SIZE="34"><B>Cepheus Online Runtime Architecture</B></FONT></TD></TR>
      </TABLE>
    >,
    labelloc=t,
    labeljust=c
  ];

  node [
    shape=box,
    style="rounded,filled",
    margin="0.21,0.13",
    width=2.70,
    height=0.72,
    fixedsize=false,
    fontname="Avenir",
    fontsize=18,
    penwidth=2.4,
    fontcolor="#14213d",
    color="#2264c7",
    fillcolor="#eaf3ff:#ffffff",
    gradientangle=270
  ];

  edge [
    color="#263a59",
    fontname="Avenir",
    fontsize=13,
    fontcolor="#3d4a5c",
    penwidth=2.2,
    arrowsize=0.78
  ];

  C1 [label=<<B>Browser App</B><BR/><FONT POINT-SIZE="15">plain DOM, Canvas, local runtime</FONT>>];
  C2 [label=<<B>Worker Routes</B><BR/><FONT POINT-SIZE="15">static assets, room HTTP, WebSocket upgrade</FONT>>];
  C3 [label=<<B>GameRoom Durable Object</B><BR/><FONT POINT-SIZE="15">ordered command boundary</FONT>>, fillcolor="#eaf8ef:#ffffff", color="#22865a"];

  subgraph cluster_shared {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="17" COLOR="#1f5fbf"><B>SHARED DOMAIN</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#496f9f">Deterministic commands, events, projectors, rulesets, and viewer projections.</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t,
      labeljust=l,
      color="#b9d8ff",
      fillcolor="#f5faff",
      style="rounded,filled",
      penwidth=1.8,
      margin=20
    ];

    S1 [label=<<B>Command metadata</B><BR/><FONT POINT-SIZE="15">route, domain, dice, expectedSeq</FONT>>];
    S2 [label=<<B>Ruleset provider</B><BR/><FONT POINT-SIZE="15">JSON decode, id, version, hash</FONT>>];
    S3 [label=<<B>Projectors</B><BR/><FONT POINT-SIZE="15">events to authoritative state</FONT>>];
    S4 [label=<<B>Viewer projection</B><BR/><FONT POINT-SIZE="15">role-safe room state</FONT>>];
  }

  subgraph cluster_storage {
    graph [
      label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="17" COLOR="#0f766e"><B>STORAGE</B></FONT></TD></TR>
          <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#357a74">Durable room truth now; R2/D1 for future assets and indexes.</FONT></TD></TR>
        </TABLE>
      >,
      labelloc=t,
      labeljust=l,
      color="#99d5cf",
      fillcolor="#f0fdfa",
      style="rounded,filled",
      penwidth=1.8,
      margin=20
    ];

    D1 [label=<<B>Event chunks</B><BR/><FONT POINT-SIZE="15">ordered append-only stream</FONT>>, fillcolor="#e6fffb:#ffffff", color="#0f766e"];
    D2 [label=<<B>Checkpoints</B><BR/><FONT POINT-SIZE="15">fast reconnect and replay tail</FONT>>, fillcolor="#e6fffb:#ffffff", color="#0f766e"];
    D3 [label=<<B>Future R2</B><BR/><FONT POINT-SIZE="15">maps, counters, archives</FONT>>, fillcolor="#fff4d1:#fffaf0", color="#d39a00"];
    D4 [label=<<B>Future D1</B><BR/><FONT POINT-SIZE="15">users, game index, audit metadata</FONT>>, fillcolor="#fff4d1:#fffaf0", color="#d39a00"];
  }

  C1 -> C2 [label="fetch / WebSocket"];
  C2 -> C3 [label="room id routes"];
  C3 -> S1 [lhead=cluster_shared, label="validate"];
  C3 -> S3 [lhead=cluster_shared, label="project"];
  C3 -> S4 [lhead=cluster_shared, label="filter"];
  C3 -> D1 [lhead=cluster_storage, label="append"];
  C3 -> D2 [lhead=cluster_storage, label="save/read"];
  S2 -> S3 [style=dashed, color="#6b7280", label="rules data"];
  S2 -> S4 [style=dashed, color="#6b7280", label="redaction data"];
}
